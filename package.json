{
  "name": "osu-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta --handle-input \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "npm --prefix server run dev",
    "build": "vite build",
    "preview": "vite preview",
    "start:api": "npm --prefix server start",
    "check": "node scripts/health-check.js",
    "install:all": "npm install && npm install --prefix server"
  },
  "dependencies": {
    "concurrently": "^9.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "vite": "^7.1.12"
  }
}
